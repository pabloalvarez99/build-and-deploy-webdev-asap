# ─── Firebase (public — safe to expose to browser) ─────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ─── Firebase Admin (secret — server only) ──────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=          # paste the full PEM key; \n are literal backslash-n from JSON

# ─── Cloud SQL / Prisma ─────────────────────────────────────────────────────
CLOUD_SQL_INSTANCE=            # e.g. tu-farmacia-prod:us-central1:tu-farmacia-db
DB_USER=farmacia-app
DB_PASSWORD=
DB_NAME=farmacia
GOOGLE_SERVICE_ACCOUNT=        # paste the full service-account JSON as a single-line string

# Local development only (Cloud SQL Auth Proxy must be running):
DATABASE_URL=postgresql://farmacia-app:PASSWORD@localhost:5432/farmacia

# ─── Payments ───────────────────────────────────────────────────────────────
TRANSBANK_ENVIRONMENT=integration   # change to 'production' with real credentials
TRANSBANK_COMMERCE_CODE=
TRANSBANK_API_KEY=

# ─── Email ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Cron ───────────────────────────────────────────────────────────────────
CRON_SECRET=                   # generate: openssl rand -hex 32

# ─── Sitemap ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tu-farmacia.cl

# ─── Vision API (scan-invoice feature) ──────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=

# ─── REMOVE THESE — no longer needed after migration ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
