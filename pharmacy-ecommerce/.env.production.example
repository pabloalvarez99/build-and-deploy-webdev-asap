# =================================
# PRODUCTION ENVIRONMENT VARIABLES
# =================================
# Copy to .env and fill in your production values

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway

# Redis (Railway Redis)
REDIS_URL=redis://default:PASSWORD@HOST.railway.app:PORT

# Auth
JWT_SECRET=generate-a-secure-64-char-random-string-here

# MercadoPago (Production credentials from mercadopago.com.cl)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-production-access-token
MERCADOPAGO_PUBLIC_KEY=APP_USR-your-production-public-key

# Service URLs (Railway URLs)
NEXT_PUBLIC_AUTH_SERVICE_URL=https://auth-service-production.up.railway.app
NEXT_PUBLIC_PRODUCT_SERVICE_URL=https://product-service-production.up.railway.app
NEXT_PUBLIC_ORDER_SERVICE_URL=https://order-service-production.up.railway.app
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-your-production-public-key

# Frontend URL (Vercel)
FRONTEND_URL=https://tu-farmacia.vercel.app

# Webhook URL (order-service on Railway)
WEBHOOK_URL=https://order-service-production.up.railway.app

# Server Ports (Railway sets PORT automatically)
SERVER_PORT=3001  # auth-service
SERVER_PORT=3002  # product-service
SERVER_PORT=3003  # order-service
